# GitLab 克隆认证（嵌入 http(s) 克隆 URL；内网仅 HTTP 亦可）
GITLAB_USER=your_gitlab_username
GITLAB_PWD=your_token_or_password

# Windows：NVM 安装根目录，例如 C:\Users\xxx\AppData\Roaming\nvm
# 脚本会将 %NVM_HOME%\v{nodeVersion} 置于 PATH 最前，实现 Node 版本隔离
NVM_HOME=C:\Program Files\nvm

# 服务端口（可选，未设置时默认 4000，与 client/vite 代理一致）
PORT=4000

# Windows 可选：发布控制台克隆/打包的工作目录（默认 C:\fe-deploy-work）
# 避免使用用户 Temp 长路径导致部分 Vite 项目在服务器上报 Rollup index.html 路径错误
# FE_DEPLOY_WORK_ROOT=D:\build\fe-deploy
